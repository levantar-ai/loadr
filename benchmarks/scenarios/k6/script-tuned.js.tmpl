import http from 'k6/http';

// A *tuned* k6 variant. The tunings below are k6's standard throughput
// best-practices; on this target (a ~60-byte JSON, sub-ms latency, co-located
// on a 6-core box) they move the needle only slightly, because k6 here is
// CPU-bound in its JS runtime + metric pipeline — not body- or
// connection-bound. They matter much more with larger response bodies.
//
//   discardResponseBodies — don't read/allocate the response body (big win on
//                           large payloads; negligible on tiny ones).
//   systemTags            — emit only the tags we report on, trimming the
//                           per-sample metric cost.
//   (run with --no-thresholds --no-usage-report — see run.sh. NOTE:
//   --compatibility-mode=base is a no-op on k6 ≥0.53 and was dropped.)
//
// The real lever for k6 throughput on this hardware is running MULTIPLE k6
// processes (k6's per-process metrics engine has a single-goroutine ceiling)
// and, above all, putting the generator on a HOST SEPARATE from the target so
// k6's heavier footprint isn't competing with the server for the same cores.
export const options = {
  vus: ${BENCH_VUS},
  duration: '${BENCH_DURATION}',
  discardResponseBodies: true,
  systemTags: ['status', 'method'],
  summaryTrendStats: ['avg', 'min', 'med', 'p(90)', 'p(95)', 'p(99)', 'max'],
};

export default function () {
  http.get('${BENCH_URL}');
}

name: bench-json
# Closed model: BENCH_VUS constant virtual users for BENCH_DURATION, looping a
# single GET as fast as they can. Rendered from this template by run.sh.
scenarios:
  default:
    executor: constant-vus
    vus: ${BENCH_VUS}
    duration: ${BENCH_DURATION}
    flow:
      - request:
          method: GET
          url: ${BENCH_URL}

package loadr:plugin@0.1.0;

/// Metadata every plugin exports so hosts can identify it.
interface meta {
    /// Static description of a plugin.
    record info {
        /// Unique plugin name (used in `plugins:` references).
        name: string,
        /// Semantic version of the plugin itself.
        version: string,
        /// One of: `extractor`, `assertion`.
        kind: string,
        /// Human readable description.
        description: string,
    }

    /// Describe this plugin.
    describe: func() -> info;
}

/// A value extractor: pulls a string out of a response body.
interface extractor {
    /// Extract a value from a response body. Returns none when no match.
    /// `config` is a JSON object with plugin-specific settings.
    extract: func(body: list<u8>, headers: list<tuple<string, string>>, config: string) -> option<string>;
}

/// A response assertion: pass/fail with a human readable detail.
interface assertion {
    /// The outcome of a check.
    record verdict {
        pass: bool,
        detail: string,
    }

    /// Check a response. `config` is a JSON object with plugin-specific settings.
    check: func(status: s64, body: list<u8>, headers: list<tuple<string, string>>, duration-ms: f64, config: string) -> verdict;
}

/// World implemented by extractor plugins.
world loadr-plugin {
    export meta;
    export extractor;
}

/// World implemented by assertion plugins.
world loadr-assertion-plugin {
    export meta;
    export assertion;
}

/// Minimal world used by the host to probe any plugin's metadata.
world loadr-meta-probe {
    export meta;
}
